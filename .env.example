# ── Local (Docker) ───────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ecommerce
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline123

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_ORDERS=ecom.orders
KAFKA_TOPIC_EVENTS=ecom.user_events

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ecommerce-lake

REDSHIFT_HOST=localhost          # Use postgres locally
REDSHIFT_PORT=5439
REDSHIFT_DB=warehouse
REDSHIFT_USER=warehouse
REDSHIFT_PASSWORD=warehouse123

AIRFLOW_UID=50000

# ── AWS (Production) ─────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

S3_BUCKET=ecommerce-data-lake-prod
REDSHIFT_CLUSTER_ENDPOINT=your-cluster.redshift.amazonaws.com
MSK_BOOTSTRAP_SERVERS=broker1:9092,broker2:9092

# ── Pipeline Config ──────────────────────────────────────────────────────────
ENVIRONMENT=local           # local | dev | prod
BATCH_DATE=2024-01-01       # Override for backfill
LOG_LEVEL=INFO
